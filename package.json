{
  "name": "kanata",
  "version": "0.4.0",
  "private": true,
  "description": "KANATA Terminal - Windows native Electron edition",
  "main": "./out/main/index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --win nsis",
    "prepare:dist": "pwsh -ExecutionPolicy Bypass -File scripts/prepare-python-dist.ps1",
    "preview": "electron-vite preview",
    "typecheck": "npm --workspace apps/renderer run typecheck && npm --workspace apps/main run typecheck",
    "test:main": "vitest run --config apps/main/vitest.config.ts",
    "test:renderer": "vitest run --config apps/renderer/vitest.config.ts",
    "test:backend": "cd backend && python -m pytest -v",
    "test:e2e": "playwright test",
    "test": "npm run test:main && npm run test:renderer && npm run test:backend"
  },
  "build": {
    "appId": "com.kanata.terminal",
    "forceCodeSigning": false,
    "productName": "KANATA Terminal",
    "copyright": "Copyright 2026 KANATA",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/tests/**"
        ]
      },
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "asar": true,
    "beforeBuild": "scripts/check-resources.cjs",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KANATA Terminal"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "electron": "^40.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  },
  "type": "module"
}
